BOT_CLIENT_ID="<YOUR_BOT_CLIENT_ID>"
BOT_CLIENT_SECRET="<YOUR_BOT_CLIENT_SECRET>"

# The absolute url of the dashboard
APP_URL="http://localhost:3000"

# Bot API endpoint (server-only, NOT exposed to client)
# Local: http://localhost:3001  |  VPS: https://bot.yourdomain.com
BOT_API_INTERNAL="http://localhost:3001"

# API key for bot API authentication (must match DASHBOARD_API_KEY in bot .env)
DASHBOARD_API_KEY=""

# User IDs allowed to access Dashboard without being server admin (comma-separated)
NEXT_PUBLIC_DASHBOARD_ADMINS=""